# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Maps API Key
# 1. Ve a https://console.cloud.google.com/
# 2. Habilita "Places API" y "Maps JavaScript API"
# 3. Crea una API key y restríngela por dominio en producción
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Resend - Servicio de envío de emails
# 1. Ve a https://resend.com/ y crea una cuenta
# 2. Genera una API key en "API Keys"
RESEND_API_KEY=re_xxxxxxxxx

# Email de destino para consultas del formulario de contacto
CONTACT_EMAIL=tu-email@ejemplo.com

# Analytics (opcionales)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_FB_PIXEL_ID=your-pixel-id

# SEO - Verificación de motores de búsqueda
# Google Search Console: https://search.google.com/search-console
# NEXT_PUBLIC_GOOGLE_VERIFICATION=tu-codigo-de-verificacion-google
# Bing Webmaster Tools: https://www.bing.com/webmasters
# NEXT_PUBLIC_BING_VERIFICATION=tu-codigo-de-verificacion-bing
# Yandex Webmaster: https://webmaster.yandex.com
# NEXT_PUBLIC_YANDEX_VERIFICATION=tu-codigo-de-verificacion-yandex

# URL del sitio (para sitemap y metadata)
# NEXT_PUBLIC_SITE_URL=https://julietaarena.com.ar

