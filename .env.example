# Google Maps API Key
# Para obtener tu API key:
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un nuevo proyecto o selecciona uno existente
# 3. Habilita "Places API" y "Maps JavaScript API"
# 4. Ve a "Credenciales" y crea una API key
# 5. Restringe la key por dominio para producción
# 6. Copia el valor en .env.local

# Resend - Servicio de envío de emails
# Para obtener tu API key:
# 1. Ve a https://resend.com/
# 2. Crea una cuenta gratuita
# 3. Ve a "API Keys" y genera una nueva key
# 4. Copia el valor aquí
RESEND_API_KEY=re_xxxxxxxxx

# Email de destino para consultas del formulario de contacto
CONTACT_EMAIL=martillerajulietaarena@gmail.com

